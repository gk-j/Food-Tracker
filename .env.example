# ============================================================
# NutriSnap — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# PostgreSQL connection string.
# On Replit this is automatically set when you add a PostgreSQL database.
# Format: postgresql://user:password@host:5432/dbname
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/nutrisnap

# ------------------------------------------------------------
# OpenAI (via Replit AI Integrations)
# These are auto-provisioned on Replit — do not set them manually there.
# For self-hosted setup outside Replit, use a real OpenAI API key and
# set the base URL to https://api.openai.com/v1
# ------------------------------------------------------------
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here

# ------------------------------------------------------------
# Mobile App
# The public domain that the Expo app uses to reach the API.
# For local development: your machine's LAN IP (e.g. 192.168.1.5)
# ------------------------------------------------------------
EXPO_PUBLIC_DOMAIN=192.168.1.5

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
