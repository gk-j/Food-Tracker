# ============================================================
# NutriSnap — .gitignore
# ============================================================

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Build output
dist/
tmp/
out-tsc/
*.tsbuildinfo
build/

# Expo
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# Dependencies
node_modules/
.pnp
.pnp.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pino-*.log

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V00
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# Test coverage
coverage/
.nyc_output/

# TypeScript incremental compilation
*.tsbuildinfo

# pnpm
.pnpm-debug.log*

# Replit-specific (local agent state — not part of the project)
.cache/
.local/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Misc
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
/typings
